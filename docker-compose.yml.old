version: "2.2"
services:
  telemt:
    image: ghcr.io/telemt/telemt:latest
    container_name: telemt-proxy
    restart: unless-stopped
    network_mode: "host"
    working_dir: /run/telemt
    read_only: true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    user: "65534:65534"
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    tmpfs:
      - /run/telemt
      - /etc/telemt
    volumes:
      - /dev/shm/telemt-tgui-config.toml:/run/telemt/config.toml:ro
